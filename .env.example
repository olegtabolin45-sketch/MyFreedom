# Скопируйте этот файл в .env и заполните значения.
# .env НЕ коммитится в репозиторий (см. .gitignore).

# Секретный ключ для подписи JWT. Сгенерируйте надёжный, например:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Время жизни access-токена (минуты) и refresh-токена (дни)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Разрешённые источники для CORS (через запятую)
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# PostgreSQL — база приложения (пользователи, цели)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=aeterna
DB_USER=aeterna
DB_PASSWORD=aeterna_local_pwd

# Redis — refresh-токены и blacklist access-токенов
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
